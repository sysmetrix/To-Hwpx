# 운영체제 자동 생성 파일
.DS_Store
Thumbs.db
desktop.ini

# 편집기 설정
.vscode/settings.json
.idea/
*.swp
*.swo

# 개발 의존성 (CDN 사용 중이라 node_modules 없음)
node_modules/
npm-debug.log*

# 환경 변수 (민감 정보)
.env
.env.local
.env.*.local

# 빌드 산출물 (현재 없음 — 순수 정적 파일)
dist/
build/

# 테스트 결과물
*.hwpx.test

# Python 캐시 (hwpx-public-doc 스크립트 실행 시 생성)
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# 로그
*.log
